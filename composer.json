{
    "name": "shobhnath/shoppingcart",
    "description": "A simple shopping cart implementation for Laravel",
    "keywords": ["laravel", "shoppingcart", "cart"],
    "license": "MIT",

    "authors": [
        {
            "name": "Shobhnath",
            "email": "shobhnath800@gmail.com"
        }
    ],

    "require": {
        "php": ">=8.1",
        "illuminate/support": "^9|^10|^11|^12",
        "illuminate/session": "^9|^10|^11|^12",
        "illuminate/events": "^9|^10|^11|^12"
    },

    "require-dev": {
        "phpunit/phpunit": "^10.0",
        "mockery/mockery": "^1.6",
        "orchestra/testbench": "^9.0"
    },

    "autoload": {
        "psr-4": {
            "Shobhnath\\Shoppingcart\\": "src/"
        }
    },

    "autoload-dev": {
        "psr-4": {
            "Shobhnath\\Tests\\Shoppingcart\\": "tests/"
        }
    },

    "extra": {
        "laravel": {
            "providers": [
                "Shobhnath\\Shoppingcart\\ShoppingcartServiceProvider"
            ],
            "aliases": {
                "Cart": "Shobhnath\\Shoppingcart\\Facades\\Cart"
            }
        }
    },

    "minimum-stability": "stable",
    "prefer-stable": true
}